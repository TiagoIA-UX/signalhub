# SignalHub — credenciais mestras (copie para .env e preencha)
# copy .env.example .env

# --- Groq (uma chave para bot + web + engine) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- Telegram (um bot para alertas do hub) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Supabase (web / qualify — um projeto) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Bot legado (Reddit + alertas) ---
LEXROCHA_BASE_URL=https://lexrocha.com.br
ZAIRYX_BASE_URL=https://www.zairyx.com.br
POLL_INTERVAL_MINUTES=5
MIN_SCORE=7
MAX_ALERTS_PER_DAY=30
DEDUP_DB_PATH=data/seen.sqlite

# --- Engine (scan) ---
REDDIT_SUBREDDITS=deliveryapp,restaurateur,smallbusiness,entrepreneur
REDDIT_LIMIT=25
SCAN_INTERVAL_SECONDS=300
MAX_ALERTAS_POR_HORA=20
