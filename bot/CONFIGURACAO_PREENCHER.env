# =============================================================================
# SIGNALHUB — ARQUIVO DE CONFIGURAÇÃO (PREENCHER E SALVAR COMO .env)
# =============================================================================
#
# INSTRUÇÕES:
# 1. Preencha os campos marcados com [PREENCHER] abaixo
# 2. Salve este arquivo como:  .env   (na mesma pasta signalhub/)
# 3. NUNCA commite o .env no Git (já está no .gitignore)
#
# Guia completo do bot: GUIA_SETUP_BOT_TELEGRAM.md
# =============================================================================

# -----------------------------------------------------------------------------
# GROQ (IA — classificação + respostas)
# Site: https://console.groq.com/keys
# Custo: free tier generoso (~centavos/mês)
# -----------------------------------------------------------------------------
GROQ_API_KEY=[PREENCHER]gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=openai/gpt-oss-120b

# -----------------------------------------------------------------------------
# TELEGRAM (alertas no seu celular)
# Bot: criado via @BotFather — ver GUIA_SETUP_BOT_TELEGRAM.md
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=[PREENCHER]123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=[PREENCHER]987654321

# -----------------------------------------------------------------------------
# URLs DOS PRODUTOS (normalmente não precisa alterar)
# -----------------------------------------------------------------------------
LEXROCHA_BASE_URL=https://lexrocha.com.br
ZAIRYX_BASE_URL=https://www.zairyx.com.br

# -----------------------------------------------------------------------------
# OPERACIONAL (valores padrão — altere só se quiser)
# -----------------------------------------------------------------------------
POLL_INTERVAL_MINUTES=5
MIN_SCORE=7
MAX_ALERTS_PER_DAY=30
DEDUP_DB_PATH=data/seen.sqlite

# =============================================================================
# CHECKLIST (marque mentalmente antes de rodar)
# =============================================================================
# [ ] Conta Groq criada + API key copiada
# [ ] Bot Telegram criado no @BotFather
# [ ] /start enviado ao bot no Telegram
# [ ] TELEGRAM_CHAT_ID obtido (script ou @userinfobot)
# [ ] Arquivo salvo como .env nesta pasta
# [ ] Teste: python run_once.py --mock --dry-run --sample
# [ ] Teste real: python run_once.py
# =============================================================================
