GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
# 1 = Agente 1 gera + Agente 2 revisa pt-PT (recomendado)
GROQ_REVISAO=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

REDDIT_SUBREDDITS=portugal,devpt
REDDIT_LIMIT=20
SCAN_INTERVAL_SECONDS=300
MAX_ALERTAS_POR_HORA=20

# Opcional — proxy socks5 para reduzir rate limit (ex.: Tor em 127.0.0.1:9150)
# DDGS_PROXY=socks5h://127.0.0.1:9150
